# ─────────────────────────────────────────────────────────────
# Flask
# ─────────────────────────────────────────────────────────────

# Long random string for session signing — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to true only during local development
FLASK_DEBUG=false

# ─────────────────────────────────────────────────────────────
# Apple App Store Connect API
# Used to fetch / create Ad Hoc Provisioning Profiles
# Docs: https://developer.apple.com/documentation/appstoreconnectapi
# ─────────────────────────────────────────────────────────────

# Key ID shown in App Store Connect → Users & Access → Keys
APPLE_KEY_ID=XXXXXXXXXX

# Issuer ID shown on the same page (UUID format)
APPLE_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Absolute path to the downloaded .p8 private key inside the container
APPLE_PRIVATE_KEY_PATH=/app/certs/AuthKey.p8

# ─────────────────────────────────────────────────────────────
# iOS Distribution Certificate (P12)
# Export from Keychain Access: File → Export → .p12
# ─────────────────────────────────────────────────────────────

# Absolute path to the .p12 file inside the container
P12_PATH=/app/certs/cert.p12

# Password set when exporting the .p12
P12_PASSWORD=your-p12-export-password

# ─────────────────────────────────────────────────────────────
# S3-Compatible Object Storage
# Tencent Cloud COS, AWS S3, MinIO, etc.
# The bucket objects must be publicly readable (iOS fetches them directly)
# ─────────────────────────────────────────────────────────────

S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key

# Endpoint URL — for Tencent COS: https://cos.<region>.myqcloud.com
#                for AWS S3:        https://s3.<region>.amazonaws.com
S3_ENDPOINT=https://cos.ap-shanghai.myqcloud.com

# Region identifier (e.g. ap-shanghai, us-east-1)
S3_REGION=ap-shanghai

# Bucket name
S3_BUCKET=your-bucket-name

# Optional key prefix / folder inside the bucket (default: ota)
S3_PREFIX=ota

# Public HTTPS base URL for serving assets — MUST be HTTPS (iOS requirement)
# Can be the bucket's default domain or a CDN / custom domain
S3_EXTERNAL_DOMAIN=https://assets.example.com

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=5005
